{
  "_comment": "gh api mutations cannot be fully pattern-blocked; skill text mandates GET-only via gh api except the documented review-comments POST.",
  "allow": [
    "Bash(gh pr list*)",
    "Bash(gh pr view*)",
    "Bash(gh pr diff*)",
    "Bash(gh pr create*)",
    "Bash(gh pr edit*)",
    "Bash(gh issue list*)",
    "Bash(gh issue view*)",
    "Bash(gh issue comment*)",
    "Bash(gh api repos/*)"
  ],
  "deny": [
    "Bash(gh pr merge*)",
    "Bash(gh pr close*)",
    "Bash(gh pr review --approve*)",
    "Bash(gh issue close*)",
    "Bash(gh issue reopen*)",
    "Bash(gh issue edit*)",
    "Bash(gh issue delete*)",
    "Bash(gh repo delete*)"
  ]
}
