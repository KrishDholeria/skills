{
  "_comment": "Render one deny per protected branch ({{PROTECTED}}), one allow per branch prefix ({{PREFIX}}).",
  "allow": [
    "Bash(git status*)",
    "Bash(git log*)",
    "Bash(git diff*)",
    "Bash(git add*)",
    "Bash(git commit*)",
    "Bash(git checkout -b *)",
    "Bash(git checkout *)",
    "Bash(git stash*)",
    "Bash(git fetch*)",
    "Bash(git pull*)",
    "Bash(git push -u origin HEAD)",
    "Bash(git push origin {{PREFIX}}*)"
  ],
  "deny": [
    "Bash(git push * {{PROTECTED}})",
    "Bash(git push origin {{PROTECTED}})",
    "Bash(git branch -D {{PROTECTED}})",
    "Bash(git reset --hard origin/{{PROTECTED}})"
  ]
}
