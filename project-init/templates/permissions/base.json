    "Bash(curl -s {{STAGING_URL}}*)",
    "Bash(curl -sf {{STAGING_URL}}*)",
    "Bash(bash ~/.claude/scripts/kb-save.sh*)",
    "Bash(bash ~/.claude/scripts/kb-search.sh*)",
    "Bash(bash ~/.claude/scripts/kb-outline.sh*)",
    "Bash(bash ~/.claude/scripts/kb-health.sh*)",
    "WebSearch"
  ],
  "deny": []
}
