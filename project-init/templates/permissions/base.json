{
  "_comment": "Universal fragment. {{CMD_*}} are rendered from project.json commands; drop entries whose command is null. {{STAGING_URL}} repeated per environment.",
  "allow": [
    "Bash({{CMD_TEST}}*)",
    "Bash({{CMD_LINT}}*)",
    "Bash({{CMD_BUILD}}*)",
